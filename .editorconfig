root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py,js,jsx,mjs,cjs,ts,tsx,mts,cts,vue,css,scss,sass,less,styl,json,md,toml,yml,yaml,html}]
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{bat,cmd,ps1}]
end_of_line = crlf
